{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.py" },
    { "src": "/api/stripe", "dest": "/api/stripe.py" },
    { "src": "/api/counter", "dest": "/api/counter.py" },
    { "src": "/api/config", "dest": "/api/config.py" },
    { "src": "/api/debug", "dest": "/api/debug.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
